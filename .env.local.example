# Supabase — get these from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for server-side admin operations (keep secret!)
# Required for persisting live quote cache rows (stock_quote_cache); optional otherwise.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Massive / Polygon.io — server only; set in .env.local (never commit)
POLYGON_API_KEY=
# Optional SEC EDGAR User-Agent (required format: "Company contact@email.com")
# SEC_EDGAR_USER_AGENT=GoldSignal.ai reports@goldsignal.ai
# Optional override (defaults to https://api.polygon.io)
# POLYGON_REST_BASE_URL=https://api.massive.com

# Supabase project ID / reference (for type generation + CLI link)
SUPABASE_PROJECT_ID=your-project-id-here

# Optional — local `npm run db:migrate` after `npx supabase login` + `supabase link`
# Production migrations run automatically on push to main (GitHub Actions; see docs/SUPABASE_MIGRATIONS.md).
# SUPABASE_ACCESS_TOKEN=
# Database password from Supabase → Settings → Database (for CLI link only; do not commit)
# SUPABASE_DB_PASSWORD=

# Portfolio review API (/api/submissions): prefers SUPABASE_SERVICE_ROLE_KEY; falls back to
# NEXT_PUBLIC_SUPABASE_ANON_KEY + migration 009_submissions_anon_insert.sql if service role is missing.
# Apply migrations 005–016 in Supabase SQL editor or via: npx supabase db push
# Key recent: 013_watchlist_signups, 014_investors_cik, 015_readout_email_tracking, 016_investors_positions

# Resend — transactional email (reports@goldsignal.ai must be verified)
RESEND_API_KEY=

# Substack CTA in filing readout emails (placeholder OK until you have the real URL)
SUBSTACK_URL=https://goldsignal.substack.com
# NEXT_PUBLIC_SUBSTACK_URL=https://goldsignal.substack.com

# Internal processing auth — generate with: openssl rand -hex 32
# Used by /api/submissions, /api/refresh-stocks, and /api/cron/cleanup when calling /api/process-one
PROCESS_SECRET=

# Public site URL (readout email links)
# NEXT_PUBLIC_SITE_URL=https://goldsignal.ai

# Vercel daily cleanup cron — generate with: openssl rand -hex 32
# Triggers stuck submission processing + stock universe refresh batch 0 (see vercel.json)
CRON_SECRET=

# /admin curation login (simple password gate)
ADMIN_PASSWORD=choose-a-strong-password

# Investor draft seed helper (`npm run seed:investors`) uses service-role client.

# GS-Investors positions: edit data/GS-Investors.xlsx in the repo (deploy to refresh public pages).
# TODO: Google Sheets sync disabled. To restore, see git history for GOOGLE_SHEETS_* env vars and investor-sheet-sync.
# GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_SHEETS_TAB_NAME=Sheet1
